# ORION Environment Variables
# ============================
# Copy this file to app/.env and fill in your values.
# Never commit app/.env to source control.

# Use Vertex AI (not AI Studio)
GOOGLE_GENAI_USE_VERTEXAI=1

# Your GCP project ID (personal account project)
GOOGLE_CLOUD_PROJECT=your-project-id

# Region where Vertex AI is enabled
GOOGLE_CLOUD_LOCATION=us-central1

# Current Gemini Live API model ID — VERIFY before each session:
# https://cloud.google.com/vertex-ai/generative-ai/docs/learn/models
# Format: gemini-2.5-flash-native-audio-preview-MMDD (changes with each release)
DEMO_AGENT_MODEL=gemini-2.5-flash-preview-native-audio-dialog

# GCS bucket name (without gs:// prefix)
GCS_BUCKET=orion-assets

# Demo patient case ID (used as CT slice directory name under GCS_BUCKET/ct/)
PATIENT_ID=case_demo_001
